#!/bin/bash
# Save as ~/bin/htop-header
# Make executable: chmod +x ~/bin/htop-header

# Create config if it doesn't exist
mkdir -p ~/.config/htop
if [ ! -f ~/.config/htop/htoprc ]; then
    cat > ~/.config/htop/htoprc << EOF
show_root_processes=1
hide_kernel_threads=1
hide_userland_threads=1
show_thread_names=0
show_program_path=0
highlight_base_name=1
highlight_deleted_exe=1
highlight_megabytes=1
highlight_threads=1
highlight_changes=0
highlight_changes_delay_secs=1
EOF
fi

# Run htop with the config
htop
