#!/bin/bash

# mkserver: Script to create a new OpenStack server with predefined parameters.

set -e

# Default values
CONTROLLER_IP=172.22.3.21
OPENRC=stacked-openrc
IMAGE=peaberry1
KEY_NAME=stardust
NETWORK=argon
SECURITY_GROUPS=("ssh" "ping")
FLAVOR=m1.small
SERVER_NAME=
VOLUME_SIZE=20
EXT_NET=stardust
BLOCK_DELETE=true

# Usage function
usage() {
    cat << EOF
Usage: $(basename "$0") -s SERVER_NAME [OPTIONS]

Create a new OpenStack server with specified parameters.

Required:
  -s SERVER_NAME        Name of the server to create

Options:
  -c CONTROLLER_IP     Controller IP address (default: $CONTROLLER_IP)
  -r OPENRC            OpenRC file name (default: $OPENRC)
  -k KEY_NAME          SSH key name (default: $KEY_NAME)
  -n NETWORK           Network name (default: $NETWORK)
  -i IMAGE             Image name (default: $IMAGE)
  -g SECURITY_GROUP    Security group (can be specified multiple times, default: ssh ping)
  -f FLAVOR            Flavor name (default: $FLAVOR)
  -v VOLUME_SIZE       Volume size in GB (default: $VOLUME_SIZE)
  -e EXT_NET           External network name (default: $EXT_NET)
  -p                   Preserve volume when server is deleted (default: delete volume)
  -h                   Display this help message

Examples:
  $(basename "$0") -s myserver
  $(basename "$0") -s myserver -g ssh -g ping -g http -v 50
  $(basename "$0") -s myserver -k mykey -n private-net -f m1.large
  $(basename "$0") -s myserver -p  # Preserve volume after server deletion

EOF
    exit 1
}

# Parse command line options
SG_OVERRIDE=false
while getopts "c:r:k:n:i:g:f:s:v:e:ph" opt; do
    case $opt in
        c) CONTROLLER_IP="$OPTARG" ;;
        r) OPENRC="$OPTARG" ;;
        k) KEY_NAME="$OPTARG" ;;
        n) NETWORK="$OPTARG" ;;
        i) IMAGE="$OPTARG" ;;
        g) 
            if [ "$SG_OVERRIDE" = false ]; then
                SECURITY_GROUPS=()
                SG_OVERRIDE=true
            fi
            SECURITY_GROUPS+=("$OPTARG")
            ;;
        f) FLAVOR="$OPTARG" ;;
        s) SERVER_NAME="$OPTARG" ;;
        v) VOLUME_SIZE="$OPTARG" ;;
        e) EXT_NET="$OPTARG" ;;
        p) BLOCK_DELETE=false ;;
        h) usage ;;
        \?) echo "Invalid option: -$OPTARG" >&2; usage ;;
        :) echo "Option -$OPTARG requires an argument." >&2; usage ;;
    esac
done

# Check required parameters
if [ -z "$SERVER_NAME" ]; then
    echo "Error: Server name is required (-s option)" >&2
    usage
fi

# Validate volume size is a number
if ! [[ "$VOLUME_SIZE" =~ ^[0-9]+$ ]]; then
    echo "Error: Volume size must be a positive integer" >&2
    exit 1
fi

# Build security group arguments
SG_ARGS=""
for sg in "${SECURITY_GROUPS[@]}"; do
    SG_ARGS="$SG_ARGS --security-group $sg"
done

# Execute all OpenStack commands in a single SSH session
echo "Creating server: $SERVER_NAME"

FLOATING_IP=$(ssh "$CONTROLLER_IP" bash <<EOF
set -e
source ~/cos-node-setup/$OPENRC
IMAGE_UUID=\$(openstack image show -f value -c id $IMAGE)

# Create the server
openstack server create \
    --key-name "$KEY_NAME" \
    --network "$NETWORK" \
    $SG_ARGS \
    --flavor "$FLAVOR" \
    --block-device source_type=image,uuid="\$IMAGE_UUID",destination_type=volume,volume_size="$VOLUME_SIZE",boot_index=0,delete_on_termination=$BLOCK_DELETE \
    "$SERVER_NAME" >/dev/null

# Wait for port to be available (max 30 seconds)
echo "Waiting for network port to be ready..."
for i in {1..30}; do
    PORT_ID=\$(openstack port list --server "$SERVER_NAME" -f value -c ID 2>/dev/null | head -n 1)
    if [ -n "\$PORT_ID" ]; then
        echo "Port ready"
        break
    fi
    sleep 1
done

if [ -z "\$PORT_ID" ]; then
    echo "Error: No port found for server" >&2
    exit 1
fi

# Create floating IP and capture it
FLOATING_IP=\$(openstack floating ip create "$EXT_NET" -f value -c floating_ip_address)

# Assign floating IP to server
openstack server add floating ip "$SERVER_NAME" "\$FLOATING_IP"

# Output the floating IP so we can capture it locally
echo "\$FLOATING_IP"
EOF
)

echo "Floating IP assigned: $FLOATING_IP"
echo -n "Building instance... "

# Start a spinner in the background while waiting for server to be ACTIVE
(
    spin='-\|/'
    i=0
    while kill -0 $$ 2>/dev/null; do
        i=$(( (i+1) %4 ))
        printf "\r${spin:$i:1} Building instance... "
        sleep 0.1
    done
) &
SPINNER_PID=$!

# Set up trap to cleanup spinner on exit
cleanup_spinner() {
    if [ -n "$SPINNER_PID" ] && kill -0 "$SPINNER_PID" 2>/dev/null; then
        kill "$SPINNER_PID" 2>/dev/null || true
        wait "$SPINNER_PID" 2>/dev/null || true
        printf "\r                                \r"
    fi
}
trap cleanup_spinner EXIT

# Wait for server to become ACTIVE
if ! ssh "$CONTROLLER_IP" bash <<EOF
set -e
source ~/cos-node-setup/$OPENRC
while true; do
    STATUS=\$(openstack server show "$SERVER_NAME" -f value -c status)
    if [ "\$STATUS" = "ACTIVE" ]; then
        break
    elif [ "\$STATUS" = "ERROR" ]; then
        echo "Server entered ERROR state" >&2
        exit 1
    fi
    sleep 2
done
EOF
then
    echo "Error: Failed to verify server status" >&2
    exit 1
fi

# Stop the spinner
kill $SPINNER_PID 2>/dev/null || true
wait $SPINNER_PID 2>/dev/null || true

# Clear the spinner line and show completion
printf "\r✓ Build complete!                \n"
echo "Server $SERVER_NAME is now active"